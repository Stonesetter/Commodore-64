10 REM NESTED FOR LOOPS DEMONSTRATION
20 REM COVERS: MULTIPLE LOOP LEVELS, INNER/OUTER VARIABLES
30 PRINT "NESTED FOR LOOPS"
40 PRINT STRING$(40, "=")
50 PRINT
60 REM TWO-LEVEL NESTING: MULTIPLICATION GRID (SMALL)
70 PRINT "3x3 MULTIPLICATION GRID:"
80 FOR I = 1 TO 3
90   FOR J = 1 TO 3
100     PRINT TAB((J-1)*8); I * J;
110   NEXT J
120   PRINT
130 NEXT I
140 PRINT
150 REM THREE-LEVEL NESTING
160 PRINT "THREE-LEVEL NESTING (COUNTING TRIPS):"
170 T = 0
180 FOR A = 1 TO 3
190   FOR B = 1 TO 3
200     FOR C = 1 TO 3
210       T = T + 1
220     NEXT C
230   NEXT B
240 NEXT A
250 PRINT "3x3x3 = "; T; " TOTAL ITERATIONS"
260 PRINT
270 REM TRIANGLE PATTERN USING NESTED LOOPS
280 PRINT "TRIANGLE PATTERN:"
290 FOR ROW = 1 TO 8
300   FOR COL = 1 TO ROW
310     PRINT "*";
320   NEXT COL
330   PRINT
340 NEXT ROW
350 PRINT
360 REM MULTIPLICATION TABLE MINI
370 PRINT "5x5 TABLE:"
380 FOR I = 1 TO 5
390   FOR J = 1 TO 5
400     PRINT TAB((J-1)*5); I*J;
410   NEXT J
420   PRINT
430 NEXT I
440 PRINT
450 REM STEP IN NESTED LOOPS
460 PRINT "STEP DEMO (EVENS IN ODDS):"
470 FOR I = 1 TO 5 STEP 2
480   PRINT "ODD "; I; ": ";
490   FOR J = 2 TO 10 STEP 2
500     PRINT J; " ";
510   NEXT J
520   PRINT
530 NEXT I
540 PRINT
550 PRINT STRING$(40, "=")
560 PRINT "NESTED FOR TESTS OK."
570 END
