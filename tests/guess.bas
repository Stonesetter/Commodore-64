10 REM GUESS A NUMBER - BASIC TEST #5
20 REM Tests: INPUT, IF/THEN with GOTO, RND, INT, string output
30 PRINT "*** GUESS MY NUMBER ***"
40 PRINT
50 N=INT(RND(1)*100)+1
60 G=0
70 PRINT "I AM THINKING OF A NUMBER FROM 1 TO 100."
80 PRINT
90 INPUT "YOUR GUESS";A
100 G=G+1
110 IF A<N THEN PRINT "TOO LOW! TRY AGAIN." : GOTO 90
120 IF A>N THEN PRINT "TOO HIGH! TRY AGAIN." : GOTO 90
130 PRINT
140 PRINT "CORRECT! THE NUMBER WAS ";N
150 IF G=1 THEN PRINT "FIRST TRY! AMAZING!" : GOTO 170
160 PRINT "YOU GOT IT IN ";G;" GUESSES."
170 END
