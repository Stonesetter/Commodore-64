10 REM ON / GOTO AND ON / GOSUB DEMONSTRATION
20 REM COVERS: COMPUTED JUMPS, MENU DISPATCH
30 PRINT "ON/GOTO AND ON/GOSUB DEMO"
40 PRINT STRING$(40, "=")
50 PRINT
60 REM BASIC ON/GOTO: INDEX 1..N SELECTS LINE
70 PRINT "ON X GOTO - SELECTING FROM 4 BRANCHES:"
80 FOR X = 1 TO 4
90   PRINT "X = "; X; " -> ";
100   ON X GOTO 200, 210, 220, 230
200   PRINT "BRANCH ONE" : GOTO 240
210   PRINT "BRANCH TWO" : GOTO 240
220   PRINT "BRANCH THREE" : GOTO 240
230   PRINT "BRANCH FOUR"
240 NEXT X
250 PRINT
260 REM ON/GOSUB - DISPATCH TO SUBROUTINES
270 PRINT "ON X GOSUB - CALLING SUBROUTINES:"
280 FOR X = 1 TO 3
290   PRINT "CALLING SUBROUTINE "; X; ":"
300   ON X GOSUB 1000, 2000, 3000
310   PRINT "  (RETURNED OK)"
320 NEXT X
330 PRINT
340 REM OUT-OF-RANGE: DOES NOTHING
350 PRINT "OUT-OF-RANGE DOES NOTHING:"
360 X = 10
370 PRINT "X ="; X; " (OUT OF RANGE, NO JUMP)"
380 ON X GOTO 400, 410, 420
390 PRINT "CONTINUED PAST ON/GOTO" : GOTO 430
400 PRINT "LINE 400" : GOTO 430
410 PRINT "LINE 410" : GOTO 430
420 PRINT "LINE 420"
430 PRINT
440 REM SIMULATE A MENU WITH ON/GOSUB
450 PRINT "SIMULATED MENU (CHOICE 1-3):"
460 CHOICE = 2
470 PRINT "SELECTED CHOICE:"; CHOICE
480 ON CHOICE GOSUB 4000, 5000, 6000
490 PRINT
500 PRINT STRING$(40, "=")
510 PRINT "ON/GOTO TESTS OK."
520 END
530
1000 PRINT "  SUBROUTINE ONE - HELLO!"
1010 RETURN
2000 PRINT "  SUBROUTINE TWO - WORLD!"
2010 RETURN
3000 PRINT "  SUBROUTINE THREE - BASIC!"
3010 RETURN
4000 PRINT "MENU OPTION 1: SHOW DATE"
4010 PRINT "  (NOT AVAILABLE IN BASIC)"
4020 RETURN
5000 PRINT "MENU OPTION 2: CALCULATE"
5010 PRINT "  PI ="; 4 * ATN(1)
5020 RETURN
6000 PRINT "MENU OPTION 3: QUIT"
6010 PRINT "  (JUST A DEMO - CONTINUING)"
6020 RETURN
