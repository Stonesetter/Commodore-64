10 REM ARRAY (DIM) DEMONSTRATION
20 REM COVERS: DIM, NUMERIC ARRAYS, STRING ARRAYS, SORTING
30 PRINT "ARRAY DEMONSTRATION"
40 PRINT STRING$(45, "=")
50 PRINT
60 REM DECLARE ARRAYS
70 DIM SCORES(9)
80 DIM NAMES$(4)
90 PRINT "NUMERIC ARRAY - STORING SQUARES:"
100 FOR I = 0 TO 9
110   SCORES(I) = I * I
120 NEXT I
130 FOR I = 0 TO 9
140   PRINT "SCORES("; I; ") = "; SCORES(I)
150 NEXT I
160 PRINT
170 REM STRING ARRAY
180 PRINT "STRING ARRAY:"
190 NAMES$(0) = "ALICE"
200 NAMES$(1) = "BOB"
210 NAMES$(2) = "CAROL"
220 NAMES$(3) = "DAVE"
230 NAMES$(4) = "EVE"
240 FOR I = 0 TO 4
250   PRINT "NAMES$("; I; ") = "; NAMES$(I)
260 NEXT I
270 PRINT
280 REM FILL WITH RANDOM VALUES AND FIND MIN/MAX
290 PRINT "RANDOM VALUES - MIN AND MAX:"
300 DIM V(9)
310 FOR I = 0 TO 9
320   V(I) = INT(RND(1) * 100)
330 NEXT I
340 PRINT "VALUES: ";
350 FOR I = 0 TO 9
360   PRINT V(I); " ";
370 NEXT I
380 PRINT
390 MN = V(0) : MX = V(0)
400 FOR I = 1 TO 9
410   IF V(I) < MN THEN MN = V(I)
420   IF V(I) > MX THEN MX = V(I)
430 NEXT I
440 PRINT "MIN = "; MN; "   MAX = "; MX
450 PRINT
460 REM SUM AND AVERAGE
470 S = 0
480 FOR I = 0 TO 9
490   S = S + V(I)
500 NEXT I
510 PRINT "SUM = "; S
520 PRINT "AVG = "; S / 10
530 PRINT
540 REM SIMPLE BUBBLE SORT
550 PRINT "BUBBLE SORT:"
560 DIM B(7)
570 B(0)=64 : B(1)=34 : B(2)=25 : B(3)=12
580 B(4)=22 : B(5)=11 : B(6)=90 : B(7)=7
590 PRINT "BEFORE: ";
600 FOR I = 0 TO 7 : PRINT B(I); " "; : NEXT I
610 PRINT
620 FOR I = 0 TO 6
630   FOR J = 0 TO 6 - I
640     IF B(J) <= B(J+1) THEN GOTO 680
650     T = B(J) : B(J) = B(J+1) : B(J+1) = T
680   NEXT J
690 NEXT I
700 PRINT "AFTER:  ";
710 FOR I = 0 TO 7 : PRINT B(I); " "; : NEXT I
720 PRINT
730 PRINT
740 PRINT STRING$(45, "=")
750 PRINT "ALL ARRAY TESTS OK."
760 END
