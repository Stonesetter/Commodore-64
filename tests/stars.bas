10 REM DIAMOND STAR PATTERN - BASIC TEST #7
20 REM Tests: STRING$, TAB, FOR/NEXT with STEP, integer arithmetic
30 PRINT "DIAMOND PATTERN:"
40 PRINT
50 FOR I=1 TO 9 STEP 2
60   PRINT TAB((20-I)/2);STRING$(I,"*")
70 NEXT I
80 FOR I=7 TO 1 STEP -2
90   PRINT TAB((20-I)/2);STRING$(I,"*")
100 NEXT I
110 PRINT
120 PRINT "TRIANGLE:"
130 PRINT
140 FOR I=1 TO 9
150   PRINT TAB(10-I);STRING$(I*2-1,"*")
160 NEXT I
170 END
