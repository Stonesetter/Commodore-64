10 REM MULTIPLICATION TABLE - BASIC TEST #8
20 REM Tests: nested FOR loops, TAB positioning, comma print zones
30 PRINT "MULTIPLICATION TABLE (1-10)"
40 PRINT STRING$(55,"-")
50 PRINT
60 REM HEADER ROW
70 PRINT TAB(5);
80 FOR J=1 TO 10
90   PRINT TAB(J*5);J;
100 NEXT J
110 PRINT
120 PRINT STRING$(55,"-")
130 FOR I=1 TO 10
140   PRINT I;TAB(5);
150   FOR J=1 TO 10
160     PRINT TAB(J*5);I*J;
170   NEXT J
180   PRINT
190 NEXT I
200 END
