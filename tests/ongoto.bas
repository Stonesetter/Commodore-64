10 REM ON...GOTO DEMO - BASIC TEST #13
20 REM Tests: ON/GOTO, ON/GOSUB, menu-driven program structure
30 PRINT "SIMPLE MENU DEMO"
40 PRINT
50 GOSUB 9000
60 PRINT
70 PRINT "SELECT AN OPTION:"
80 PRINT "  1. SQUARES"
90 PRINT "  2. CUBES"
100 PRINT "  3. POWERS OF 2"
110 PRINT "  4. QUIT"
120 PRINT
130 INPUT "CHOICE (1-4)";C
140 IF C<1 OR C>4 THEN PRINT "INVALID! TRY AGAIN." : GOTO 130
150 ON C GOSUB 1000, 2000, 3000, 4000
160 IF C<>4 THEN GOTO 50
170 END

1000 REM --- SQUARES ---
1010 PRINT
1020 PRINT "SQUARES 1-10:"
1030 FOR I=1 TO 10 : PRINT I;"^2 =";I*I : NEXT I
1040 RETURN

2000 REM --- CUBES ---
2010 PRINT
2020 PRINT "CUBES 1-10:"
2030 FOR I=1 TO 10 : PRINT I;"^3 =";I*I*I : NEXT I
2040 RETURN

3000 REM --- POWERS OF 2 ---
3010 PRINT
3020 PRINT "POWERS OF 2:"
3030 FOR I=0 TO 15 : PRINT "2^";I;" =";2^I : NEXT I
3040 RETURN

4000 REM --- QUIT ---
4010 PRINT
4020 PRINT "GOODBYE!"
4030 RETURN

9000 REM --- DRAW BANNER ---
9010 PRINT STRING$(30,"*")
9020 PRINT "*  BSDBASIC MENU DEMO       *"
9030 PRINT STRING$(30,"*")
9040 RETURN
