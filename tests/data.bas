10 REM DATA/READ/RESTORE DEMO - BASIC TEST #10
20 REM Tests: DATA, READ, RESTORE, string and numeric data, mixed types
30 PRINT "DATA/READ DEMONSTRATION"
40 PRINT
50 PRINT "READING PLANET DATA:"
60 PRINT STRING$(45,"-")
70 PRINT "PLANET          MOONS   DIST(AU)"
80 PRINT STRING$(45,"-")
90 FOR I=1 TO 8
100   READ P$, M, D
110   PRINT P$;TAB(17);M;TAB(25);D
120 NEXT I
130 PRINT STRING$(45,"-")
140 PRINT
150 PRINT "RESTORING AND READING JUST NAMES:"
160 RESTORE
170 FOR I=1 TO 8
180   READ P$, M, D
190   PRINT P$;" ";
200 NEXT I
210 PRINT
220 END

