10 REM SIEVE OF ERATOSTHENES - BASIC TEST #6
20 REM Tests: DIM arrays, nested FOR loops, IF/THEN with GOTO
30 PRINT "PRIME NUMBERS UP TO 200:"
40 PRINT
50 DIM P(201)
60 FOR I=2 TO 200
70   P(I)=1
80 NEXT I
90 FOR I=2 TO 14
100   IF P(I)=0 THEN GOTO 130
110   FOR J=I*2 TO 200 STEP I
120     P(J)=0
125   NEXT J
130 NEXT I
140 C=0
150 FOR I=2 TO 200
160   IF P(I)=0 THEN GOTO 190
170   PRINT I;" ";
180   C=C+1
190 NEXT I
200 PRINT
210 PRINT
220 PRINT "TOTAL: ";C;" PRIMES FOUND."
230 END
