10 REM FIZZBUZZ - BASIC TEST #14
20 REM Tests: IF/THEN/ELSE chaining, MOD via INT, multiple conditions
30 REM Note: No MOD operator in CBM BASIC - use: N - INT(N/D)*D
40 PRINT "FIZZBUZZ (1-50):"
50 PRINT
60 FOR I=1 TO 50
70   REM CHECK FIZZBUZZ FIRST (divisible by both 3 and 5)
80   IF I - INT(I/15)*15 = 0 THEN PRINT "FIZZBUZZ" : GOTO 130
90   IF I - INT(I/3)*3 = 0 THEN PRINT "FIZZ" : GOTO 130
100  IF I - INT(I/5)*5 = 0 THEN PRINT "BUZZ" : GOTO 130
110  PRINT I
120  GOTO 130
130 NEXT I
140 PRINT
150 PRINT "DONE! (TOTAL ";I-1;" NUMBERS)"
160 END
