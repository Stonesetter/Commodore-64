10 REM GOSUB/RETURN DEMO - BASIC TEST #9
20 REM Tests: GOSUB, RETURN, nested subroutines, subroutine reuse
30 PRINT "GOSUB/RETURN DEMONSTRATION"
40 PRINT
50 PRINT "CALLING DRAW LINE:"
60 GOSUB 1000
70 PRINT "BACK FROM SUBROUTINE"
80 PRINT
90 PRINT "FACTORIAL CALCULATIONS:"
100 FOR N=1 TO 8
110   GOSUB 2000
120   PRINT N;"! = ";F
130 NEXT N
140 PRINT
150 GOSUB 1000
160 PRINT "ALL DONE!"
170 END

1000 REM --- SUBROUTINE: DRAW LINE ---
1010 PRINT STRING$(40,"-")
1020 RETURN

2000 REM --- SUBROUTINE: FACTORIAL ---
2010 REM INPUT: N   OUTPUT: F
2020 F=1
2030 FOR K=2 TO N
2040   F=F*K
2050 NEXT K
2060 RETURN
